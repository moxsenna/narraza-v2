{
  "name": "@narraza/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./repositories/*": {
      "types": "./dist/repositories/*.d.ts",
      "import": "./dist/repositories/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@narraza/application": "*",
    "@narraza/shared": "*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
