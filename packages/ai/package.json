{
  "name": "@narraza/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prompts/contracts/*": {
      "types": "./dist/prompts/contracts/*.d.ts",
      "import": "./dist/prompts/contracts/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
