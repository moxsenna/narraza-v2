// M0: identity, session, challenge, project shell
// M1.1a/b: canon entities, prose, proposals, validation artifacts
// M3.0: jobs, credits, outbox, workflow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  suspended
  deleted
}

enum FoundationStatus {
  none
  draft
  locked
}

enum ProjectStartMode {
  guided
  advanced
}

enum FactCanonStatus {
  confirmed
  deprecated
  contradicted
}

enum ProseStatus {
  draft
  validated
  rejected
  superseded
}

enum ProposalSource {
  ai
  user
  system
}

enum ProposalStatus {
  pending
  accepted
  rejected
  stale
  superseded
  needs_revalidation
}

enum GenerationJobStatus {
  queued
  running
  succeeded
  failed
  dead
  cancelled
}

enum GenerationAttemptStatus {
  started
  completed
  failed
  unknown
}

enum CreditReservationStatus {
  reserved
  closing
  closed
}

enum AttemptCostExposureStatus {
  open
  settled
  released
}

enum CreditQuoteStatus {
  issued
  consumed
  expired
}

enum OutboxEventStatus {
  pending
  processing
  completed
  dead
}

enum OutboxReceiptStatus {
  processing
  completed
  uncertain
  dead
}

enum WorkflowInvocationStatus {
  pending
  started
  completed
  failed
  timed_out
}

enum AuditEventClass {
  credit
  job
  proposal
  canon
  auth
  outbox
  system
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailNormalized String   @map("email_normalized")
  name          String?
  status        UserStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime?  @map("deleted_at") @db.Timestamptz(3)

  accounts   Account[]
  sessions   Session[]
  projects   Project[]
  challenges EmailLoginChallenge[]

  creditLedgerEntries CreditLedger[]
  generationJobs      GenerationJob[]
  creditReservations  CreditReservation[]
  creditQuotes        CreditQuote[]
  concurrencySlots    UserConcurrencySlot[]
  auditEvents         AuditEvent[]
  workingDrafts       ProseWorkingDraft[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique @map("session_token")
  userId       String    @map("user_id")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(3)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model EmailLoginChallenge {
  id                   String    @id @default(cuid())
  userId               String?   @map("user_id")
  identifierNormalized String    @map("identifier_normalized")
  tokenHash            String    @map("token_hash")
  nonce                String
  expiresAt            DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt           DateTime? @map("consumed_at") @db.Timestamptz(3)
  revokedAt            DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([identifierNormalized, createdAt])
  @@index([tokenHash])
  @@map("email_login_challenges")
}

model Project {
  id                      String           @id @default(cuid())
  ownerUserId             String           @map("owner_user_id")
  title                   String
  startMode               ProjectStartMode @default(guided) @map("start_mode")
  foundationStatus        FoundationStatus @default(none) @map("foundation_status")
  currentCanonicalVersion Int              @default(0) @map("current_canonical_version")
  createRequestId         String?          @map("create_request_id")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt               DateTime?        @map("deleted_at") @db.Timestamptz(3)

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  foundation        Foundation?
  characters        Character[]
  facts             Fact[]
  entityRevisions   CanonicalEntityRevision[]
  reveals           Reveal[]
  chapterOutlines   ChapterOutline[]
  chapters          Chapter[]
  proposalGroups    ProposalGroup[]
  changeSets        CanonicalChangeSet[]
  contextSnapshots  ContextSnapshot[]
  contextBundles    GenerationContextBundle[]
  publishArtifacts  PublishPackageArtifact[]

  generationJobs GenerationJob[]
  auditEvents    AuditEvent[]

  @@unique([ownerUserId, createRequestId])
  @@index([ownerUserId])
  @@map("projects")
}

/// Append-only ledger for credit grants, settlements, refunds, adjustments.
/// Expanded from M0 minimal model; dedupe_key unique index already exists.
model CreditLedger {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  entryType   String   @map("entry_type")
  amountMicro BigInt   @map("amount_micro")
  dedupeKey   String   @unique @map("dedupe_key")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_ledger")
}

// =============================================================================
// M1.1a: Canon entity tables
// =============================================================================

model Foundation {
  id        String   @id @default(cuid())
  projectId String   @unique @map("project_id")
  premise   String?  @db.Text
  tone      String?
  genre     String?
  body      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("foundations")
}

model Character {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  beliefs CharacterBelief[]
  states  CharacterState[]

  @@index([projectId])
  @@map("characters")
}

model Fact {
  id          String          @id @default(cuid())
  projectId   String          @map("project_id")
  factKey     String          @map("fact_key")
  truth       String          @db.Text
  canonStatus FactCanonStatus @default(confirmed) @map("canon_status")
  revision    Int             @default(1)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reveals            Reveal[]
  beliefSources      CharacterBelief[]
  allowedInBeats     BeatAllowedFact[]
  forbiddenInBeats   BeatForbiddenFact[]

  @@index([projectId])
  @@map("facts")
}

model CharacterBelief {
  id                String   @id @default(cuid())
  characterId       String   @map("character_id")
  beliefKey         String   @map("belief_key")
  effectiveSequence Int      @map("effective_sequence")
  beliefContent     String   @map("belief_content") @db.Text
  confidence        Float    @default(1.0)
  sourceFactId      String?  @map("source_fact_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sourceFact Fact?    @relation(fields: [sourceFactId], references: [id], onDelete: SetNull)

  @@unique([characterId, beliefKey, effectiveSequence])
  @@index([characterId])
  @@index([sourceFactId])
  @@map("character_beliefs")
}

model CharacterState {
  id          String   @id @default(cuid())
  characterId String   @map("character_id")
  sequence    Int
  state       Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, sequence])
  @@map("character_states")
}

model Reveal {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  revealKey String    @map("reveal_key")
  factId    String    @map("fact_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact    Fact    @relation(fields: [factId], references: [id], onDelete: Cascade)

  breadcrumbs RevealBreadcrumb[]

  @@index([projectId])
  @@index([factId])
  @@map("reveals")
}

model RevealBreadcrumb {
  id        String   @id @default(cuid())
  revealId  String   @map("reveal_id")
  beatId    String   @map("beat_id")
  placement String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  reveal Reveal @relation(fields: [revealId], references: [id], onDelete: Cascade)
  beat   Beat   @relation(fields: [beatId], references: [id], onDelete: Cascade)

  @@index([revealId])
  @@index([beatId])
  @@map("reveal_breadcrumbs")
}

model ChapterOutline {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  chapterNumber Int      @map("chapter_number")
  title         String?
  summary       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, chapterNumber])
  @@index([projectId])
  @@map("chapter_outlines")
}

model Chapter {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  number    Int
  title     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  beats Beat[]

  @@unique([projectId, number])
  @@index([projectId])
  @@map("chapters")
}

model Beat {
  id                     String   @id @default(cuid())
  chapterId              String   @map("chapter_id")
  beatNumber             Int      @map("beat_number")
  acceptedProseVersionId String?  @map("accepted_prose_version_id")
  title                  String?
  summary                String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  chapter          Chapter              @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  proseVersions    ProseVersion[]
  allowedFacts     BeatAllowedFact[]
  forbiddenFacts   BeatForbiddenFact[]
  breadcrumbs      RevealBreadcrumb[]
  contextSnapshots ContextSnapshot[]
  contextBundles   GenerationContextBundle[]

  workingDrafts ProseWorkingDraft[]

  @@unique([chapterId, beatNumber])
  @@index([chapterId])
  @@map("beats")
}

model BeatAllowedFact {
  id     String @id @default(cuid())
  beatId String @map("beat_id")
  factId String @map("fact_id")

  beat Beat @relation(fields: [beatId], references: [id], onDelete: Cascade)
  fact Fact @relation(fields: [factId], references: [id], onDelete: Cascade)

  @@unique([beatId, factId])
  @@map("beat_allowed_facts")
}

model BeatForbiddenFact {
  id     String @id @default(cuid())
  beatId String @map("beat_id")
  factId String @map("fact_id")

  beat Beat @relation(fields: [beatId], references: [id], onDelete: Cascade)
  fact Fact @relation(fields: [factId], references: [id], onDelete: Cascade)

  @@unique([beatId, factId])
  @@map("beat_forbidden_facts")
}

// =============================================================================
// M1.1b: Prose, proposals, validation artifacts
// =============================================================================

model ProseVersion {
  id          String      @id @default(cuid())
  beatId      String      @map("beat_id")
  version     Int
  content     String      @db.Text
  contentHash String      @map("content_hash")
  status      ProseStatus @default(draft)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  beat        Beat               @relation(fields: [beatId], references: [id], onDelete: Cascade)
  validations ValidationReport[]
  candidates  GeneratedCandidate[]

  @@unique([beatId, id])
  @@unique([beatId, version])
  @@index([beatId])
  @@map("prose_versions")
}

model ValidationReport {
  id             String   @id @default(cuid())
  proseVersionId String   @map("prose_version_id")
  candidateId    String?  @map("candidate_id")
  passed         Boolean
  findings       Json
  contentHash    String   @map("content_hash")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  proseVersion ProseVersion        @relation(fields: [proseVersionId], references: [id], onDelete: Cascade)
  candidate    GeneratedCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([proseVersionId])
  @@index([candidateId])
  @@map("validation_reports")
}

model GeneratedCandidate {
  id                  String   @id @default(cuid())
  generationAttemptId String?  @map("generation_attempt_id")
  candidateIndex      Int      @map("candidate_index")
  rawResponseBody     String?  @map("raw_response_body") @db.Text
  parsedOutput        Json?    @map("parsed_output")
  normalizedOps       Json?    @map("normalized_ops")
  canonicalOps        Json?    @map("canonical_ops")
  operationsHash      String?  @map("operations_hash")
  proseVersionId      String?  @map("prose_version_id")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  generationAttempt GenerationAttempt? @relation(fields: [generationAttemptId], references: [id], onDelete: SetNull)
  proseVersion      ProseVersion?      @relation(fields: [proseVersionId], references: [id], onDelete: SetNull)
  validationReports ValidationReport[]

  @@index([generationAttemptId])
  @@map("generated_candidates")
}

model ProposalGroup {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  @@index([projectId])
  @@map("proposal_groups")
}

model Proposal {
  id                        String         @id @default(cuid())
  proposalGroupId           String         @map("proposal_group_id")
  source                    ProposalSource
  status                    ProposalStatus @default(pending)
  dependencyHash            String         @map("dependency_hash")
  operationsHash            String         @map("operations_hash")
  revalidatedFromProposalId String?        @map("revalidated_from_proposal_id")
  changeSetId               String?        @map("change_set_id")
  createdAt                 DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  proposalGroup ProposalGroup @relation(fields: [proposalGroupId], references: [id], onDelete: Cascade)
  revalidatedFrom Proposal?   @relation("ProposalRevalidation", fields: [revalidatedFromProposalId], references: [id], onDelete: SetNull)
  revalidatedBy   Proposal[]  @relation("ProposalRevalidation")
  changeSet       CanonicalChangeSet?

  @@index([proposalGroupId])
  @@index([revalidatedFromProposalId])
  @@index([changeSetId])
  @@map("proposals")
}

model CanonicalChangeSet {
  id         String    @id @default(cuid())
  projectId  String    @map("project_id")
  proposalId String?   @unique @map("proposal_id")
  status     String    @default("pending")
  appliedAt  DateTime? @map("applied_at") @db.Timestamptz(3)
  rejectedAt DateTime? @map("rejected_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  project           Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proposal          Proposal?                @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  operations        CanonicalChangeOperation[]
  revisions         CanonicalEntityRevision[]
  publishArtifacts  PublishPackageArtifact[]

  @@index([projectId])
  @@map("canonical_change_sets")
}

model CanonicalChangeOperation {
  id          String   @id @default(cuid())
  changeSetId String   @map("change_set_id")
  sequence    Int
  opType      String   @map("op_type")
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  changeSet CanonicalChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@unique([changeSetId, sequence])
  @@map("canonical_change_operations")
}

model CanonicalEntityRevision {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  changeSetId    String   @map("change_set_id")
  revision       Int      @default(1)
  previousHash   String?  @map("previous_hash")
  newHash        String   @map("new_hash")
  operationCount Int      @default(1) @map("operation_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeSet CanonicalChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@unique([entityId, revision])
  @@index([projectId])
  @@index([changeSetId])
  @@map("canonical_entity_revisions")
}

model ContextSnapshot {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  beatId       String?  @map("beat_id")
  snapshotType String   @map("snapshot_type")
  payload      Json
  contentHash  String   @map("content_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beat    Beat?   @relation(fields: [beatId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([beatId])
  @@map("context_snapshots")
}

model GenerationContextBundle {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  beatId      String?  @map("beat_id")
  bundleType  String   @map("bundle_type")
  payload     Json
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beat    Beat?   @relation(fields: [beatId], references: [id], onDelete: SetNull)

  generationJobs GenerationJob[]

  @@index([projectId])
  @@index([beatId])
  @@map("generation_context_bundles")
}

model PublishPackageArtifact {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  changeSetId  String   @map("change_set_id")
  artifactType String   @map("artifact_type")
  contentHash  String   @map("content_hash")
  payload      Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeSet CanonicalChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([changeSetId])
  @@map("publish_package_artifacts")
}

// =============================================================================
// M3.0: Jobs, credits, outbox, workflow, audit, prose working draft
// =============================================================================

model GenerationJob {
  id                  String              @id @default(cuid())
  ownerUserId         String              @map("owner_user_id")
  projectId           String              @map("project_id")
  status              GenerationJobStatus @default(queued)
  jobType             String              @map("job_type")
  payloadJson         Json                @map("payload_json")
  runAfter            DateTime            @default(now()) @map("run_after") @db.Timestamptz(3)
  priority            Int                 @default(0)
  leaseToken          String?             @map("lease_token")
  leaseVersion        Int                 @default(0) @map("lease_version")
  leaseExpiresAt      DateTime?           @map("lease_expires_at") @db.Timestamptz(3)
  leaseOwner          String?             @map("lease_owner")
  cancelRequestedAt   DateTime?           @map("cancel_requested_at") @db.Timestamptz(3)
  executionRetryCount Int                 @default(0) @map("execution_retry_count")
  maxExecutionRetries Int                 @default(3) @map("max_execution_retries")
  terminalAt          DateTime?           @map("terminal_at") @db.Timestamptz(3)
  terminalReasonCode  String?             @map("terminal_reason_code")
  conflictKey         String?             @map("conflict_key")
  requestId           String              @unique @map("request_id")
  workflowPlanId      String?             @map("workflow_plan_id")
  contextBundleId     String?             @map("context_bundle_id")
  reservationId       String?             @map("reservation_id")
  retryOfJobId        String?             @map("retry_of_job_id")
  nextAttemptNumber   Int                 @default(1) @map("next_attempt_number")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner               User                        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  project             Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contextBundle       GenerationContextBundle?    @relation(fields: [contextBundleId], references: [id], onDelete: SetNull)
  retryOf             GenerationJob?              @relation("JobRetry", fields: [retryOfJobId], references: [id], onDelete: SetNull)
  retriedBy           GenerationJob[]             @relation("JobRetry")
  attempts            GenerationAttempt[]
  workflowInvocations WorkflowInvocation[]
  reservations        CreditReservation[]
  creditQuotes        CreditQuote[]
  concurrencySlots    UserConcurrencySlot[]

  @@index([ownerUserId])
  @@index([projectId])
  @@map("generation_jobs")
}

model GenerationAttempt {
  id                   String                  @id @default(cuid())
  generationJobId      String                  @map("generation_job_id")
  workflowInvocationId String?                 @map("workflow_invocation_id")
  status               GenerationAttemptStatus @default(started)
  attemptNumber        Int                     @map("attempt_number")
  leaseToken           String?                 @map("lease_token")
  deadlineAt           DateTime?               @map("deadline_at") @db.Timestamptz(3)
  retryDisposition     String?                 @map("retry_disposition")
  providerRequestId    String?                 @map("provider_request_id")
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  generationJob      GenerationJob        @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  workflowInvocation WorkflowInvocation?  @relation(fields: [workflowInvocationId], references: [id], onDelete: SetNull)
  costExposures      AttemptCostExposure[]
  usageEvents        AIUsageEvent[]
  candidates         GeneratedCandidate[]

  @@index([generationJobId])
  @@index([workflowInvocationId])
  @@map("generation_attempts")
}

model WorkflowInvocation {
  id                String                     @id @default(cuid())
  generationJobId   String                     @map("generation_job_id")
  routingStage      String                     @map("routing_stage")
  invocationKey     String                     @map("invocation_key")
  selectedAttemptId String?                    @map("selected_attempt_id")
  status            WorkflowInvocationStatus   @default(pending)
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  generationJob GenerationJob      @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  attempts      GenerationAttempt[]

  @@index([generationJobId])
  @@map("workflow_invocations")
}

model CreditReservation {
  id              String                   @id @default(cuid())
  jobId           String                   @map("job_id")
  userId          String                   @map("user_id")
  reservedAmount  BigInt                   @map("reserved_amount")
  settledAmount   BigInt                   @default(0) @map("settled_amount")
  releasedAmount  BigInt                   @default(0) @map("released_amount")
  status          CreditReservationStatus  @default(reserved)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  job          GenerationJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  costExposures AttemptCostExposure[]

  @@index([jobId])
  @@index([userId])
  @@map("credit_reservations")
}

model AttemptCostExposure {
  id                    String                      @id @default(cuid())
  generationAttemptId   String                      @map("generation_attempt_id")
  reservationId         String                      @map("reservation_id")
  estimatedAmountMicro  BigInt                      @map("estimated_amount_micro")
  actualAmountMicro     BigInt?                     @map("actual_amount_micro")
  status                AttemptCostExposureStatus   @default(open)
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)

  generationAttempt GenerationAttempt  @relation(fields: [generationAttemptId], references: [id], onDelete: Cascade)
  reservation       CreditReservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([generationAttemptId])
  @@index([reservationId])
  @@map("attempt_cost_exposures")
}

model CreditQuote {
  id                       String            @id @default(cuid())
  ownerUserId              String            @map("owner_user_id")
  workflowPlanHash         String            @map("workflow_plan_hash")
  dependencyHash           String            @map("dependency_hash")
  estimatedMaximumMicroIdr BigInt            @map("estimated_maximum_micro_idr")
  expiresAt                DateTime          @map("expires_at") @db.Timestamptz(3)
  consumedByJobId          String?           @unique @map("consumed_by_job_id")
  status                   CreditQuoteStatus @default(issued)
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner      User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  consumedBy GenerationJob? @relation(fields: [consumedByJobId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@map("credit_quotes")
}

model UserConcurrencySlot {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  jobId      String    @map("job_id")
  slotKey    String    @map("slot_key")
  acquiredAt DateTime  @default(now()) @map("acquired_at") @db.Timestamptz(3)
  releasedAt DateTime? @map("released_at") @db.Timestamptz(3)

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_concurrency_slots")
}

model AIUsageEvent {
  id                  String   @id @default(cuid())
  generationAttemptId String   @map("generation_attempt_id")
  modelId             String   @map("model_id")
  provider            String
  inputTokens         Int?     @map("input_tokens")
  outputTokens        Int?     @map("output_tokens")
  costMicroIdr        BigInt?  @map("cost_micro_idr")
  providerReportedCost Json?   @map("provider_reported_cost")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  generationAttempt GenerationAttempt @relation(fields: [generationAttemptId], references: [id], onDelete: Cascade)

  @@map("ai_usage_events")
}

model OutboxEvent {
  id                 String             @id @default(cuid())
  dedupeKey          String             @map("dedupe_key")
  status             OutboxEventStatus  @default(pending)
  payload            Json
  availableAt        DateTime           @default(now()) @map("available_at") @db.Timestamptz(3)
  deliveryGeneration Int                @default(0) @map("delivery_generation")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  receipts OutboxConsumerReceipt[]

  @@map("outbox_events")
}

model OutboxConsumerReceipt {
  id                String               @id @default(cuid())
  consumerName      String               @map("consumer_name")
  eventId           String               @map("event_id")
  deliveryGeneration Int                 @map("delivery_generation")
  status            OutboxReceiptStatus  @default(processing)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  event OutboxEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("outbox_consumer_receipts")
}

model AuditEvent {
  id              String         @id @default(cuid())
  eventClass      AuditEventClass @map("event_class")
  actorUserId     String?        @map("actor_user_id")
  tenantProjectId String?        @map("tenant_project_id")
  payload         Json
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  actor  User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant Project? @relation(fields: [tenantProjectId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([tenantProjectId])
  @@index([createdAt])
  @@map("audit_events")
}

model WorkerInstance {
  id              String   @id @default(cuid())
  instanceId      String   @unique @map("instance_id")
  role            String
  lastHeartbeatAt DateTime @map("last_heartbeat_at") @db.Timestamptz(3)
  draining        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([lastHeartbeatAt])
  @@map("worker_instances")
}

model ModelPriceSnapshot {
  id                  String    @id @default(cuid())
  modelId             String    @map("model_id")
  provider            String
  inputPriceMicroIdr  BigInt    @map("input_price_micro_idr")
  outputPriceMicroIdr BigInt    @map("output_price_micro_idr")
  effectiveAt         DateTime  @map("effective_at") @db.Timestamptz(3)
  deprecatedAt        DateTime? @map("deprecated_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([modelId, provider, effectiveAt])
  @@map("model_price_snapshots")
}

model ProseWorkingDraft {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  beatId      String    @map("beat_id")
  content     String    @db.Text
  contentHash String    @map("content_hash")
  version     Int       @default(1)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  beat Beat @relation(fields: [beatId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([beatId])
  @@map("prose_working_drafts")
}
